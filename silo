#!/usr/bin/env python3
"""
silo: Unified Downloader Dashboard Dispatcher.

This shim acts as the primary entry point for the silo suite, allowing users
to switch between qBittorrent, SABnzbd, and (future) rTorrent views.
"""

import os
import sys
from pathlib import Path

BIN_DIR = Path(__file__).parent.resolve() / "bin"

# Subcommand → script, description (shown in --help / --list)
_COMMANDS: list[tuple[str, Path, str]] = [
    ("qbit",    BIN_DIR / "silo-dashboard.py",  "qBittorrent dashboard (default)"),
    ("rt",      BIN_DIR / "silo-dashboard.py",  "rTorrent dashboard (press \\ inside to switch)"),
    ("rtorrent",BIN_DIR / "silo-dashboard.py",  "rTorrent dashboard (alias for rt)"),
    ("sab",     BIN_DIR / "silo-sabnzbd.py",    "SABnzbd dashboard"),
    ("sabnzbd", BIN_DIR / "silo-sabnzbd.py",    "SABnzbd dashboard (alias for sab)"),
]
DASHBOARDS = {cmd: path for cmd, path, _ in _COMMANDS}


def _print_help() -> None:
    print("Usage: silo [subcommand] [options]")
    print()
    print("Subcommands:")
    seen: set[str] = set()
    for cmd, _, desc in _COMMANDS:
        print(f"  {cmd:<12} {desc}")
    print()
    print("With no subcommand, 'qbit' is used by default.")
    print("Pass --help after a subcommand to see its options.")


def main():
    argv = sys.argv[1:]

    if argv and argv[0] in ("-h", "--help") and len(argv) == 1:
        _print_help()
        sys.exit(0)

    if argv and argv[0] == "--list":
        for cmd, _, _ in _COMMANDS:
            print(cmd)
        sys.exit(0)

    # Default to qbit if no subcommand is provided
    subcommand = "qbit"
    if argv and argv[0] in DASHBOARDS:
        subcommand = argv[0]
        argv = argv[1:]
    elif argv and argv[0].startswith("-"):
        subcommand = "qbit"
    elif argv:
        print(f"silo: unknown subcommand '{argv[0]}'", file=sys.stderr)
        print("Run 'silo --help' for usage.", file=sys.stderr)
        sys.exit(1)

    script_path = DASHBOARDS[subcommand]
    if not script_path.exists():
        print(f"ERROR: Dashboard script not found: {script_path}", file=sys.stderr)
        sys.exit(1)

    # Use os.execve to replace the current process with the target dashboard
    env = os.environ.copy()
    os.execve(sys.executable, [sys.executable, str(script_path), *argv], env)


if __name__ == "__main__":
    main()
